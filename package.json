{
  "name": "fing",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bunx tauri dev",
    "build": "bun run scripts/tauri-build.ts",
    "build:mac:universal": "bun run build -- --target universal-apple-darwin",
    "frontend:dev": "bunx --bun vite",
    "frontend:build": "bunx --bun vite build",
    "typecheck": "tsc --noEmit",
    "lint": "bunx --bun ultracite check",
    "lint:fix": "bunx --bun ultracite fix",
    "release:version": "bun run scripts/release.ts bump",
    "release:verify-tag": "bun run scripts/release.ts verify-tag",
    "release:notes": "bun run scripts/release.ts notes"
  },
  "dependencies": {
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "lucide": "0.575.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.0",
    "@tauri-apps/api": "2.10.1",
    "@tauri-apps/cli": "2.10.0",
    "typescript": "^5.7.3",
    "ultracite": "7.2.4",
    "vite": "^7.3.1"
  }
}
