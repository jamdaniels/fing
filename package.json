{
  "name": "fing",
  "private": true,
  "version": "1.2.0-rc1",
  "type": "module",
  "scripts": {
    "dev": "bunx tauri dev --config src-tauri/tauri.dev.conf.json",
    "build": "bun run scripts/tauri-build.ts",
    "build:dev": "bun run scripts/tauri-build.ts --config src-tauri/tauri.dev.conf.json",
    "build:mac:universal": "bun run build -- --target universal-apple-darwin",
    "frontend:dev": "bunx --bun vite",
    "frontend:build": "bunx --bun vite build",
    "test": "bun run test:ts && bun run test:rust",
    "test:ts": "bun test",
    "test:rust": "bun run frontend:build && cargo test --manifest-path src-tauri/Cargo.toml",
    "typecheck": "tsc --noEmit",
    "lint": "bunx --bun biome check --no-errors-on-unmatched .",
    "lint:fix": "bunx --bun biome check --write --no-errors-on-unmatched .",
    "verify": "bun run lint && bun run typecheck && bun run test:ts && bun run test:rust",
    "release:version": "bun run scripts/release.ts bump",
    "release:verify-tag": "bun run scripts/release.ts verify-tag",
    "release:notes": "bun run scripts/release.ts notes"
  },
  "dependencies": {
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "lucide": "^1.14.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/cli": "^2.10.1",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
