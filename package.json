{
  "name": "fing",
  "private": true,
  "version": "1.0.2-rc1",
  "type": "module",
  "scripts": {
    "dev": "bunx tauri dev",
    "build": "bun run scripts/tauri-build.ts",
    "build:mac:universal": "bun run build -- --target universal-apple-darwin",
    "frontend:dev": "bunx --bun vite",
    "frontend:build": "bunx --bun vite build",
    "test": "bun run test:ts && bun run test:rust",
    "test:ts": "bun test",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "typecheck": "tsc --noEmit",
    "lint": "bunx --bun ultracite check",
    "lint:fix": "bunx --bun ultracite fix",
    "release:version": "bun run scripts/release.ts bump",
    "release:verify-tag": "bun run scripts/release.ts verify-tag",
    "release:notes": "bun run scripts/release.ts notes"
  },
  "dependencies": {
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "lucide": "^1.14.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/cli": "^2.10.1",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3",
    "ultracite": "^7.6.2",
    "vite": "^8.0.10"
  },
  "overrides": {
    "brace-expansion": "5.0.5"
  }
}
