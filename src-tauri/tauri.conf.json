{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fing",
  "identifier": "com.jamdaniels.fing",
  "version": "1.0.0-rc4",
  "build": {
    "beforeDevCommand": "bun run frontend:dev",
    "beforeBuildCommand": "bun run frontend:build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": false,
    "security": {
      "csp": {
        "default-src": "'self' customprotocol: asset:",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' asset: http://asset.localhost blob: data:",
        "connect-src": "'self' ipc: http://ipc.localhost",
        "object-src": "'none'",
        "base-uri": "'self'"
      }
    },
    "windows": [
      {
        "label": "main",
        "title": "",
        "width": 800,
        "height": 600,
        "visible": false,
        "resizable": false,
        "center": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      },
      {
        "label": "indicator",
        "title": "",
        "url": "indicator.html",
        "width": 70,
        "height": 30,
        "visible": false,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": false,
        "focus": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "sounds/*"
    ],
    "macOS": {
      "entitlements": "entitlements.plist",
      "minimumSystemVersion": "10.15",
      "infoPlist": "Info.plist"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": [
        "https://github.com/jamdaniels/fing/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFCREIzOEY4OERGOTA2MzUKUldRMUJ2bU4rRGpicXhoWGsySC9JL0FKZCt0aGdLb3FNRERYVVVoY25wU3E1WEVqcDNWdURXZ2gK"
    }
  }
}
