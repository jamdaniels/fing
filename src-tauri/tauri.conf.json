{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fing",
  "identifier": "com.jamdaniels.fing",
  "version": "0.1.0",
  "build": {
    "beforeDevCommand": "bun run frontend:dev",
    "beforeBuildCommand": "bun run frontend:build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "security": {
      "csp": {
        "default-src": "'self' customprotocol: asset:",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' asset: http://asset.localhost blob: data:",
        "connect-src": "'self' ipc: http://ipc.localhost"
      }
    },
    "windows": [
      {
        "label": "main",
        "title": "",
        "width": 800,
        "height": 600,
        "visible": false,
        "resizable": true,
        "minWidth": 600,
        "minHeight": 400,
        "center": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      },
      {
        "label": "indicator",
        "title": "",
        "url": "indicator.html",
        "width": 70,
        "height": 30,
        "visible": false,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["sounds/*"],
    "macOS": {
      "entitlements": "entitlements.plist",
      "minimumSystemVersion": "10.15",
      "infoPlist": "Info.plist"
    }
  },
  "plugins": {}
}
